# Production build (npm run build) for the VPS.
# Leave empty when the built SPA and the API are served from the same domain
# (recommended: reverse-proxy /api to the Go backend). Set to a full URL only
# if the API lives on a separate host, e.g. https://api.your-domain.com
# NOTE: Vite embeds VITE_* vars into the public bundle — never put secrets here.
VITE_API_BASE_URL=
