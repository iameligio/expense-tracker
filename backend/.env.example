# Server
PORT=8080
# Comma-separated list of allowed SPA origins (CORS).
# Local (Valet): https://expense-tracker.test  ·  Production: https://your-domain.com
CORS_ORIGINS=https://expense-tracker.test,http://localhost:5173

# Force Secure cookies when served over TLS even outside production
# (e.g. behind Valet at https://*.test). Defaults to true when ENV=production.
COOKIE_SECURE=true

# Database (MariaDB / MySQL)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=expense_tracker

# Auth
# Use a long random secret in production (e.g. `openssl rand -base64 48`)
JWT_SECRET=change-me-in-production-please-use-a-long-random-value
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_HOURS=168

# The account registered with this email is automatically promoted to admin
ADMIN_EMAIL=admin@example.com

# Set to "production" to enable Secure cookies / HSTS
ENV=development
